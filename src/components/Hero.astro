---
---
<section class="relative min-h-screen flex flex-col justify-end px-6 md:px-12 pb-20 pt-32 overflow-hidden">

  <div class="relative max-w-6xl">
    <!-- Pre-heading -->
    <p class="text-xs tracking-[0.3em] uppercase text-muted mb-8">Branding studio — Strategy-first</p>

    <!-- Main heading -->
    <h1 class="font-display font-extrabold text-[clamp(3rem,8vw,7rem)] leading-[0.95] text-crema mb-8">
      Brands that make<br />
      <span class="text-tierra">people choose you</span><br />
      before they compare.
    </h1>

    <!-- Sub -->
    <p class="max-w-xl text-lg text-muted-2 leading-relaxed mb-12">
      We build brand identities for ambitious companies — from positioning to visual system to launch.
      Strategy-led, design-executed, results-measured.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap items-center gap-4">
      <a
        href="#contact"
        class="px-8 py-4 bg-fractura text-antracita font-semibold rounded-full hover:bg-fractura-dark transition-colors"
      >Start a project</a>
      <a
        href="#work"
        class="px-8 py-4 border border-panel-2 text-crema font-medium rounded-full hover:border-muted transition-colors"
      >See our work</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 right-12 hidden md:flex flex-col items-center gap-2 text-muted">
    <span class="text-xs tracking-widest uppercase" style="writing-mode: vertical-rl;">Scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-muted to-transparent"></div>
  </div>
</section>
