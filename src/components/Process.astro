---
const steps = [
  {
    num: "01",
    title: "Discovery",
    desc: "We learn your business, your audience, and what makes you different. Interviews, audits, and research — so we build on truth, not assumptions.",
    duration: "1–2 weeks",
  },
  {
    num: "02",
    title: "Strategy",
    desc: "Before design touches a screen, we define your positioning, brand voice, and visual direction. This is the foundation everything is built on.",
    duration: "1–2 weeks",
  },
  {
    num: "03",
    title: "Design",
    desc: "We build your identity system — logo, typography, color, motion principles, and every touchpoint your audience will encounter.",
    duration: "3–5 weeks",
  },
  {
    num: "04",
    title: "Handoff",
    desc: "Full brand guidelines, file libraries, and implementation support. You leave with everything you need to run the brand — and a team to call when you grow.",
    duration: "1 week",
  },
];
---
<section id="process" class="px-6 md:px-12 py-28 bg-panel/30">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-16">
      <p class="text-xs tracking-[0.3em] uppercase text-muted mb-3">How we work</p>
      <h2 class="font-display font-extrabold text-[clamp(2rem,5vw,3.5rem)] text-crema leading-tight">
        A process built<br />to reduce risk.
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-4 gap-px bg-panel">
      {steps.map((s) => (
        <div class="bg-antracita p-8 group hover:bg-panel transition-colors duration-300">
          <div class="text-tierra font-display font-bold text-5xl mb-8 leading-none">{s.num}</div>
          <h3 class="font-display font-bold text-xl text-crema mb-4">{s.title}</h3>
          <p class="text-sm text-muted-2 leading-relaxed mb-8">{s.desc}</p>
          <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-tierra animate-pulse-dot"></div>
            <span class="text-xs text-muted tracking-wide">{s.duration}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom note -->
    <p class="mt-8 text-sm text-muted text-center">
      Total engagement: typically <span class="text-crema">8–12 weeks</span> from kickoff to full handoff.
    </p>
  </div>
</section>
