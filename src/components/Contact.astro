---
---
<section id="contact" class="px-6 md:px-12 py-28 bg-panel/30">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-start">
    <!-- Left -->
    <div>
      <p class="text-xs tracking-[0.3em] uppercase text-muted mb-5">Start a project</p>
      <h2 class="font-display font-extrabold text-[clamp(2.5rem,5vw,4rem)] text-crema leading-tight mb-6">
        Let's build something<br />
        <span class="text-tierra">worth remembering.</span>
      </h2>
      <p class="text-muted-2 leading-relaxed max-w-md mb-10">
        Tell us about your project. We'll respond within 48 hours with a brief assessment and, if it's
        a good fit, a proposal call.
      </p>

      <div class="space-y-4 text-sm">
        <div class="flex items-center gap-3 text-muted">
          <div class="w-1.5 h-1.5 rounded-full bg-tierra"></div>
          <span>Projects start at <span class="text-crema">$4,500</span></span>
        </div>
        <div class="flex items-center gap-3 text-muted">
          <div class="w-1.5 h-1.5 rounded-full bg-tierra"></div>
          <span>Response within <span class="text-crema">48 hours</span></span>
        </div>
        <div class="flex items-center gap-3 text-muted">
          <div class="w-1.5 h-1.5 rounded-full bg-tierra"></div>
          <span>Free 30-min discovery call</span>
        </div>
      </div>
    </div>

    <!-- Right: Form -->
    <form
      class="bg-panel rounded-2xl p-8 border border-panel-2 space-y-5"
      onsubmit="event.preventDefault()"
    >
      <div class="grid grid-cols-2 gap-4">
        <div class="flex flex-col gap-2">
          <label class="text-xs text-muted tracking-wide uppercase" for="name">Name</label>
          <input
            id="name"
            type="text"
            placeholder="Your name"
            class="bg-antracita border border-panel-2 rounded-lg px-4 py-3 text-crema text-sm placeholder:text-muted focus:outline-none focus:border-tierra transition-colors"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label class="text-xs text-muted tracking-wide uppercase" for="company">Company</label>
          <input
            id="company"
            type="text"
            placeholder="Your company"
            class="bg-antracita border border-panel-2 rounded-lg px-4 py-3 text-crema text-sm placeholder:text-muted focus:outline-none focus:border-tierra transition-colors"
          />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-xs text-muted tracking-wide uppercase" for="email">Email</label>
        <input
          id="email"
          type="email"
          placeholder="you@company.com"
          class="bg-antracita border border-panel-2 rounded-lg px-4 py-3 text-crema text-sm placeholder:text-muted focus:outline-none focus:border-tierra transition-colors"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-xs text-muted tracking-wide uppercase" for="service">Service</label>
        <select
          id="service"
          class="select-arrow bg-antracita border border-panel-2 rounded-lg px-4 py-3 text-crema text-sm focus:outline-none focus:border-tierra transition-colors appearance-none"
        >
          <option value="" disabled selected>What are you looking for?</option>
          <option value="identity">Brand Identity</option>
          <option value="strategy">Brand Strategy</option>
          <option value="digital">Digital Design</option>
          <option value="sprint">Brand Sprint</option>
          <option value="unsure">Not sure yet</option>
        </select>
      </div>

      <div class="flex flex-col gap-2">
        <label class="text-xs text-muted tracking-wide uppercase" for="message">Brief</label>
        <textarea
          id="message"
          rows="4"
          placeholder="Tell us about your brand, your goals, and your timeline..."
          class="bg-antracita border border-panel-2 rounded-lg px-4 py-3 text-crema text-sm placeholder:text-muted focus:outline-none focus:border-tierra transition-colors resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-4 bg-fractura text-antracita font-semibold rounded-full hover:bg-fractura-dark transition-colors"
      >Send inquiry →</button>
    </form>
  </div>
</section>
